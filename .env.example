# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/book_generator

# LLM Configuration (LiteLLM supports many providers: groq, openai, anthropic, etc.)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=your_llm_api_key_here

# Storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./storage
